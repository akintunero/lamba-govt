# Lamba Government Digital Services Platform
# Run `bash generate-env.sh` to generate a .env with random secrets
# DO NOT use this file directly — it is a reference only

# Database
POSTGRES_USER=lamba
POSTGRES_PASSWORD=lamba
POSTGRES_DB=lamba_platform
DATABASE_URL=postgres://lamba:lamba@localhost:5433/lamba_platform

# Secrets (autogenerated — use generate-env.sh)
JWT_SECRET=
SERVICE_AUTH_TOKEN=

# Seed accounts (autogenerated)
SEED_STUDENT_EMAIL=student@gov.lamba
SEED_STUDENT_PASSWORD=
SEED_ADMIN_EMAIL=admin@gov.lamba
SEED_ADMIN_PASSWORD=

# Object storage (autogenerated)
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Kafka
KAFKA_BROKERS=kafka:9092

# Keycloak
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=lamba-platform
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_ID=internal-services
KEYCLOAK_CLIENT_SECRET=
API_GATEWAY_CLIENT_ID=api-gateway
API_GATEWAY_CLIENT_SECRET=

# Diagnostics
DIAGNOSTICS_TOKEN=

# CTF flags (autogenerated — random each deployment)
CTF_FLAG_A01_IDOR=
CTF_FLAG_A02_JWT_FORGE=
CTF_FLAG_A03_SQLI=
CTF_FLAG_A04_PREDICTABLE_RESET=
CTF_FLAG_A05_INTERNAL_GATEWAY=
CTF_FLAG_A05_METRICS_LINE=
CTF_FLAG_A06_PROTOTYPE_POLLUTION=
CTF_FLAG_A07_SESSION_FIXATION=
CTF_FLAG_A08_MASS_ASSIGNMENT=
CTF_FLAG_A09_AUDIT_SPOOF=
CTF_FLAG_A10_SSRF=
CTF_FLAG_A10_DIAGNOSTICS=
CTF_FLAG_CRYPTO_PADDING_ORACLE=
CTF_FLAG_FORENSICS_LOG_ANALYSIS=
CTF_FLAG_TIMING_ATTACK=
CTF_CRYPTO_KEY=
CTF_CRYPTO_IV=

# Misc
REQUEST_ACCESS_LOGS=false
FILE_STORAGE_SERVICE_URL=http://localhost:3007
