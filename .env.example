# Lamba Government Digital Services Platform

POSTGRES_USER=lamba
POSTGRES_PASSWORD=lamba
POSTGRES_DB=lamba_platform
DATABASE_URL=postgres://lamba:lamba@localhost:5433/lamba_platform

JWT_SECRET=lamba-platform-signing-key-v1
SERVICE_AUTH_TOKEN=lamba-inter-service-token-v1

SEED_STUDENT_EMAIL=student@gov.lamba
SEED_STUDENT_PASSWORD=
SEED_ADMIN_EMAIL=admin@gov.lamba
SEED_ADMIN_PASSWORD=

MINIO_ACCESS_KEY=lamba
MINIO_SECRET_KEY=lamba-secret-key
MINIO_ENDPOINT=minio
MINIO_PORT=9000

KAFKA_BROKERS=kafka:9092

KEYCLOAK_ENABLED=true
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=lamba-platform
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

OPENSEARCH_URL=http://localhost:9200
LEGACY_DATABASE_URL=postgres://lamba:lamba@localhost:5433/lamba_legacy

DIAGNOSTICS_TOKEN=

# Hybrid CTF flags (see platform/config/ctf-flags.env.example)
CTF_FLAG_A01_IDOR=FLAG{A01_lamba_IDOR_bypass_success}
CTF_FLAG_A02_JWT_FORGE=FLAG{A02_jwt_signature_forged}
CTF_FLAG_A03_SQLI=FLAG{A03_sqli_exfiltration_achieved}
CTF_FLAG_A05_INTERNAL_GATEWAY=FLAG{A05_internal_gateway_exposure}
CTF_FLAG_A05_METRICS_LINE=lamba_ctf_flag{status="A05_metrics_leak"} 1
CTF_FLAG_A07_SESSION_FIXATION=FLAG{A07_session_fixation_bypass}
CTF_FLAG_A08_MASS_ASSIGNMENT=FLAG{A08_mass_assignment_priv_esc}
CTF_FLAG_A09_AUDIT_SPOOF=FLAG{A09_audit_log_spoofing_success}
CTF_FLAG_A10_SSRF=FLAG{A10_ssrf_registry_success}
CTF_FLAG_A10_DIAGNOSTICS=FLAG{A10_diagnostics_verbose_success}

# Set REQUEST_ACCESS_LOGS=true only when debugging HTTP routing (never in production CTF runs)
REQUEST_ACCESS_LOGS=false

FILE_STORAGE_SERVICE_URL=http://localhost:3007
REPORTING_SERVICE_URL=http://localhost:3008
