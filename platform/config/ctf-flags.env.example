# Hybrid CTF validation flags (copy into .env or platform/config/ctf-flags.env)
CTF_FLAG_A01_IDOR=FLAG{A01_lamba_IDOR_bypass_success}
CTF_FLAG_A02_JWT_FORGE=FLAG{A02_jwt_signature_forged}
CTF_FLAG_A03_SQLI=FLAG{A03_sqli_exfiltration_achieved}
CTF_FLAG_A05_INTERNAL_GATEWAY=FLAG{A05_internal_gateway_exposure}
CTF_FLAG_A05_METRICS_LINE=lamba_ctf_flag{status="A05_metrics_leak"} 1
CTF_FLAG_A07_SESSION_FIXATION=FLAG{A07_session_fixation_bypass}
CTF_FLAG_A08_MASS_ASSIGNMENT=FLAG{A08_mass_assignment_priv_esc}
CTF_FLAG_A09_AUDIT_SPOOF=FLAG{A09_audit_log_spoofing_success}
CTF_FLAG_A10_SSRF=FLAG{A10_ssrf_registry_success}
CTF_FLAG_A10_DIAGNOSTICS=FLAG{A10_diagnostics_verbose_success}
